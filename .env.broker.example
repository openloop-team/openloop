# OpenLoop external broker — broker-process environment only
#
# Copy to .env.broker and fill every placeholder. This file is gitignored and
# is loaded only by the `broker` service in docker-compose.broker.yml.
#
# TRUST PARTITION (load-bearing):
#   .env.broker: capability/runtime roots + identity/receipt PUBLIC keys
#   .env:        identity PRIVATE key + receipt roots + app/provider secrets
# Never copy broker-side roots into .env. Never copy app-side signing material
# into this file. DATABASE_URL is deliberately shared by both processes because
# Postgres is a shared dependency, not a signing trust domain.

DATABASE_URL=postgresql://openloop:change-me@postgres:5432/openloop

# Independent base64-encoded 32-byte roots, encoded as JSON maps. Do not reuse
# bytes within or across either map or with any app-side root/key.
BROKER_CAPABILITY_ROOTS={"cap-key-v1":"REPLACE_WITH_BASE64_32_BYTE_ROOT"}
BROKER_CAPABILITY_CURRENT_VERSION=cap-key-v1
BROKER_RUNTIME_ROOTS={"runtime-key-v1":"REPLACE_WITH_DIFFERENT_BASE64_32_BYTE_ROOT"}
BROKER_RUNTIME_CURRENT_VERSION=runtime-key-v1

# Base64-encoded raw 32-byte Ed25519 public keys. Identity public keys correspond
# to BROKER_IDENTITY_PRIVATE_KEY in .env. Receipt publics correspond to the
# domain/version-derived signing keys rooted at BROKER_RECEIPT_ROOTS in .env.
BROKER_IDENTITY_PUBLIC_KEYS={"identity-v1":"REPLACE_WITH_BASE64_ED25519_PUBLIC"}
BROKER_RECEIPT_PUBLIC_KEYS={"receipt-key-v1":"REPLACE_WITH_BASE64_ED25519_PUBLIC"}
