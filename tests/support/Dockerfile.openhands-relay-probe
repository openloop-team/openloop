FROM python@sha256:423ed6ab25b1921a477529254bfeeabf5855151dc2c3141699a1bfc852199fbf AS builder

WORKDIR /opt/openloop-relay-probe

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    UV_NO_CACHE=1 \
    UV_PYTHON_DOWNLOADS=never

# The probe uses the same frozen dependency graph as the runtime without
# installing the OpenLoop project itself; the live test mounts the current
# source tree read-only so it exercises the code under test.
RUN apt-get update && \
    apt-get install --yes --no-install-recommends git && \
    rm -rf /var/lib/apt/lists/*
RUN pip install uv==0.11.14

COPY pyproject.toml uv.lock README.md ./
ARG OPENHANDS_PROBE_VERSION=""
RUN if [ -z "${OPENHANDS_PROBE_VERSION}" ]; then \
        uv sync --frozen --no-dev --extra openhands --no-install-project; \
    else \
        uv venv .venv && \
        uv pip install --python .venv/bin/python \
            "openhands-agent-server==${OPENHANDS_PROBE_VERSION}" \
            "openhands-sdk==${OPENHANDS_PROBE_VERSION}" \
            "openhands-tools==${OPENHANDS_PROBE_VERSION}" \
            "openhands-workspace==${OPENHANDS_PROBE_VERSION}"; \
    fi

FROM python@sha256:423ed6ab25b1921a477529254bfeeabf5855151dc2c3141699a1bfc852199fbf

WORKDIR /opt/openloop-relay-probe

COPY --from=builder /opt/openloop-relay-probe/.venv .venv

ENV PATH="/opt/openloop-relay-probe/.venv/bin:${PATH}" \
    PYTHONDONTWRITEBYTECODE=1

ENTRYPOINT ["python"]
