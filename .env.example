# OpenLoop — example environment configuration
#
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# NEVER commit your real `.env`. Use least-privilege, scoped credentials.
# These keys are PRELIMINARY and will evolve as the runtime lands.

# -----------------------------------------------------------------------------
# Compose sibling-container sandboxes (optional)
# -----------------------------------------------------------------------------
# Read by docker-compose.sandbox.yml, not by the OpenLoop settings model.
# Docker API access is daemon-equivalent authority: use the override only for a
# trusted, single-tenant runtime. Defaults shown below are normally sufficient;
# On Linux with rootful Docker, the default below is normally sufficient.
#DOCKER_SOCKET=/var/run/docker.sock
# Required when the runtime image runs as a non-root user. On the Docker host:
#   stat -c '%g' /var/run/docker.sock
# Then set the printed numeric group ID here before recreating the runtime.
#DOCKER_GID=999
# Docker Desktop for Mac without its optional /var/run/docker.sock symlink:
#DOCKER_SOCKET=${HOME}/.docker/run/docker.sock
# Rootless Docker users should likewise set their absolute user socket path.
# Required by docker-compose.sandbox.yml: choose a stable absolute host path,
# pre-create it, and make it writable by the runtime's numeric UID/GID. The
# override mounts it at the identical container path for sibling bind mounts.
#OPENLOOP_SANDBOX_ROOT=/var/lib/openloop/sandboxes

# -----------------------------------------------------------------------------
# Model providers (configure at least one)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Local / self-hosted models via Ollama (optional)
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# Slack surface
# -----------------------------------------------------------------------------
# Create a Slack app and use scoped, least-privilege tokens. Sealed analysis
# over files shared in a thread additionally requires the bot `files:read`
# scope; hosted report delivery uses `files:write`.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# -----------------------------------------------------------------------------
# End-to-end test credentials (optional — only for the live E2E suite)
# -----------------------------------------------------------------------------
# Used by tests/e2e/*, never by the app runtime, hence the E2E_ prefix.
# The live Slack test posts the triggering mention as a *human*: Slack drops
# app_mention for a bot mentioning itself. Needs user-token scope chat:write.
E2E_SLACK_USER_TOKEN=
E2E_SLACK_CHANNEL=

# -----------------------------------------------------------------------------
# GitHub connector (optional, for issues / PRs)
# -----------------------------------------------------------------------------
# Prefer a fine-grained token scoped to only the repos the agent needs.
# The coding worker additionally needs contents:write + pull-requests:write.
GITHUB_TOKEN=

# Preferred over GITHUB_TOKEN: a GitHub App whose short-lived installation
# tokens are minted on demand (all three required; needs `pip install
# pyopenloop[githubapp]`). When both are set the App wins.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_INSTALLATION_ID=
# Optional least-privilege restriction: comma-separated bare repo names (no
# owner). Unset = minted tokens span every repo the installation can access.
GITHUB_APP_REPOSITORIES=

# Coding worker (optional). Runs model-generated edits, so it stays OFF unless
# enabled and needs a contents:write token + an isolated checkout.
CODING_WORKER_ENABLED=false
CODING_WORKER_MODEL=anthropic/claude-sonnet-4-6
# Which worker engine edits the prepared workspace:
#   builtin   (default) — OpenLoop's own light worker: one model call for a
#             unified diff, applied via the sandbox below.
#   openhands — the heavy agentic worker (install the `openhands` extra).
#             Requires a fail-closed spend cap: the owning agent's
#             spec.budget.per_task_usd — every attempt's spend is recorded to
#             the usage store and an over-budget attempt fails before any
#             push/PR. Refuses to register without the cap.
#   claude    — EXPERIMENTAL / personal use: drives the `claude` CLI headless
#             (`claude -p`), authenticating with whatever `claude` is logged
#             into, INCLUDING a Pro/Max subscription. Needs the `claude` binary
#             in the image + subscription auth (see CLAUDE settings below).
#             Host sandbox ONLY (docker fails closed). Bounded by
#             CODING_WORKER_MAX_ITERATIONS + CODING_WORKER_DEADLINE_SECONDS —
#             its load-bearing fail-closed cap, since the subscription dollar
#             signal is unreliable. ToS: the subscription is meant for
#             individual use, not a shared team runtime — read src/openloop/
#             tools/claude_worker.py before enabling on a team surface.
# FAIL-CLOSED: an unknown value disables the coding worker loudly.
CODING_WORKER_BACKEND=builtin
# In-run iteration cap for the OpenHands conversation / claude `--max-turns`
# (for openhands the budget cap is the per-task ledger above; for claude this
# is half the fail-closed bound, the deadline below is the other half).
CODING_WORKER_MAX_ITERATIONS=100
# Wall-clock ceiling for one attempt. OpenHands: a soft deadline between agent
# events (0 disables). claude: a HARD subprocess kill and its load-bearing
# fail-closed bound — must be > 0 for that backend.
CODING_WORKER_DEADLINE_SECONDS=600
# --- claude backend auth (CODING_WORKER_BACKEND=claude) ---
# Preferred: a long-lived subscription token from `claude setup-token`, run on
# a machine already logged into your Pro/Max plan. No credential mount needed.
# (Alternative: mount ~/.claude + ~/.claude.json into the runtime — see
# docker-compose.deploy.yml. The token is cleaner in a container.)
#CLAUDE_CODE_OAUTH_TOKEN=
# Path to the CLI if it isn't on PATH as `claude`.
#CODING_WORKER_CLAUDE_BIN=claude
# Headless permission handling: acceptEdits (default, auto-accepts file edits)
# or bypassPermissions (full autonomy incl. shell/tests — the disposable,
# credential-free workspace makes this defensible, and it avoids per-attempt
# directory-trust stalls; recommended only because that workspace is throwaway).
#CODING_WORKER_CLAUDE_PERMISSION_MODE=acceptEdits
# OpenHands docker runtime (CODING_WORKER_BACKEND=openhands +
# CODING_WORKER_SANDBOX=docker): the agent server runs in its own container
# with the attempt workspace bind-mounted at /workspace — it edits through
# the mount and never holds a git credential; the host commits and pushes.
CODING_WORKER_OPENHANDS_IMAGE=ghcr.io/openhands/agent-server@sha256:08d3994f9287f8d52b07907ac1575ecfaa48b972697ddae4f1cb5c2f03713fab
# Docker network for that container. Unset = default bridge (the agent loop
# runs in-container and needs egress to the model provider — "none" would
# break it). Point at an egress-proxy network for an allowlist model.
#CODING_WORKER_OPENHANDS_NETWORK=egress-proxy
# How the runtime reaches the agent-server. "loopback" (default) publishes
# 127.0.0.1:<port> on the Docker daemon host — correct for host-run. When the
# runtime itself is a container (docker-compose.sandbox.yml), set "network" to
# publish nothing and dial by container name over the shared network above;
# the override sets both automatically.
#CODING_WORKER_OPENHANDS_CONNECT=loopback
# Host-owned state is isolated per job and kept outside every checkout. Unset
# defaults to <system-temp>/openloop/openhands; configure a shared durable path
# before enabling cold resume across replicas.
#CODING_WORKER_OPENHANDS_STATE_DIR=/var/lib/openloop/openhands
# REQUIRED for Docker OpenHands: a dedicated base64-encoded 32-byte secret
# (for example: openssl rand -base64 32). Never reuse a Slack/GitHub/provider
# secret. The value is redacted from Settings representations and logs.
#CODING_WORKER_OPENHANDS_STATE_MASTER_KEY=
CODING_WORKER_OPENHANDS_MASTER_KEY_ID=key-v1
# Default-on for Docker OpenHands. Host-mode OpenHands fails closed while this
# is enabled because it has no durable authenticated agent-server lifecycle.
CODING_WORKER_OPENHANDS_COLD_RESUME_ENABLED=true
# Where the worker's model-influenced execution (applying generated edits) runs:
#   host   (default) — plain subprocess, no isolation.
#   docker — throwaway container per command: default-deny egress (network
#            none), no env forwarded, capabilities dropped. FAIL-CLOSED: a
#            boot probe runs a REAL container with the configured image,
#            network, and workspace mount; if any of it can't work the coding
#            worker is disabled — it never silently falls back to the host.
# With CODING_WORKER_BACKEND=openhands the same switch picks where the agent
# runs: host = in-process, docker = containerized agent server over the
# mounted workspace (see CODING_WORKER_OPENHANDS_* above).
CODING_WORKER_SANDBOX=host
# Image for the docker sandbox (needs `git` on PATH).
CODING_WORKER_SANDBOX_IMAGE=alpine/git
# Container network: "none" = default-deny (the worker needs no egress — the
# model call happens in the controller). Point at a user-defined docker
# network fronted by an egress proxy for an allowlist model.
CODING_WORKER_SANDBOX_NETWORK=none
# Workspace directory (default: system tempdir). REQUIRED when the runtime is
# itself containerized with the docker sandbox. The Compose sandbox override
# sets this automatically beneath OPENLOOP_SANDBOX_ROOT; set it yourself only
# for a non-Compose container deployment using the same-path mount invariant.
#CODING_WORKER_WORKSPACE_DIR=/var/lib/openloop/workspaces

# Sealed analysis worker (optional). Runs model-authored Python over an approved
# manifest of staged, thread-upload, and/or GitHub-archive inputs. It is OFF by
# default and has no host mode or network escape hatch: Docker, `network=none`,
# a successful sealed probe, and a digest-pinned image are all required or the
# tool is disabled.
ANALYSIS_WORKER_ENABLED=false
ANALYSIS_WORKER_BACKEND=builtin
ANALYSIS_WORKER_MODEL=anthropic/claude-sonnet-4-6
ANALYSIS_WORKER_SANDBOX=docker
ANALYSIS_WORKER_SANDBOX_NETWORK=none
# Temporary default: official Python 3.12 slim, pinned by immutable multi-arch
# digest. It supports stdlib analysis only. Override it with the image built
# from docker/analysis.Dockerfile for pandas/numpy/matplotlib. Mutable tags are
# rejected (the value must contain @sha256:).
ANALYSIS_WORKER_SANDBOX_IMAGE=python@sha256:423ed6ab25b1921a477529254bfeeabf5855151dc2c3141699a1bfc852199fbf
# Required for a containerized OpenLoop runtime, as with coding workspaces. The
# Compose sandbox override sets it automatically beneath
# OPENLOOP_SANDBOX_ROOT; other deployments must mount the host path into the
# runtime at the exact same location.
#ANALYSIS_WORKER_WORKSPACE_DIR=/var/lib/openloop/analysis-workspaces
ANALYSIS_WORKER_TIMEOUT_SECONDS=120
ANALYSIS_WORKER_MEMORY=512m
ANALYSIS_WORKER_CPUS=1
ANALYSIS_WORKER_PIDS_LIMIT=128
ANALYSIS_WORKER_TMP_SIZE=64m
ANALYSIS_WORKER_REPORT_MAX_BYTES=1000000
# One approved request may merge several sources, but never retain more than
# this total in controller memory. Download-specific caps fire while streaming.
# Repo archives extract into ANALYSIS_WORKER_TMP_SIZE; raise tmpfs + memory for
# repo-shaped workloads after rehearsing with representative inputs.
#ANALYSIS_WORKER_MAX_INPUT_BYTES=33554432
#ANALYSIS_WORKER_GITHUB_MAX_BYTES=33554432
#ANALYSIS_WORKER_UPLOAD_MAX_BYTES=16777216
# Strategy inside the builtin backend: "iterative" (default — refinement loop
# with capped execution feedback) or "single" (one completion, one sealed run).
# Iterative spend is bounded even without a dollar cap: at most
# MAX_ITERATIONS completions per human-approved attempt, with hard-capped
# feedback growth. Agents carrying spec.budget.per_task_usd additionally get
# the in-run spend abort and the fail-closed settle at that cap.
ANALYSIS_WORKER_STRATEGY=iterative
#ANALYSIS_WORKER_MAX_ITERATIONS=4
#ANALYSIS_WORKER_EXEC_FEEDBACK_MAX_CHARS=16384
# Opt-in hard gate (openhands-style): require spec.budget.per_task_usd on
# every agent exposing the analysis tool, or disable the worker at boot.
#ANALYSIS_WORKER_REQUIRE_PER_TASK_CAP=1

# -----------------------------------------------------------------------------
# External coding-worker broker (optional Compose process split)
# -----------------------------------------------------------------------------
# Use only with docker-compose.broker.yml. The override sets BROKER_MODE,
# enables the broker-backed OpenHands path, and derives all shared paths from
# OPENLOOP_BROKER_ROOT. Keep this file app-side: broker capability/runtime roots
# and broker-side public maps belong only in .env.broker (copy its example).
#OPENLOOP_BROKER_ROOT=/var/lib/openloop/broker
# Changing either numeric identity requires `docker compose ... up --build` so
# the image passwd/group entries stay aligned with Compose and provisioning.
#OPENLOOP_BROKER_UID=10002
#OPENLOOP_DATA_GID=10777
# Required by the broker service for the host Docker socket (Linux example):
#DOCKER_GID=999
#DOCKER_SOCKET=/var/run/docker.sock

# App-held identity signing seed: base64-encoded 32 bytes. Publish only its raw
# Ed25519 public key as BROKER_IDENTITY_PUBLIC_KEYS in .env.broker.
#BROKER_IDENTITY_PRIVATE_KEY=
BROKER_IDENTITY_KEY_ID=identity-v1
BROKER_IDENTITY_ISSUER=openloop-app
BROKER_IDENTITY_AUDIENCE=openloop-broker

# App/checkpoint-store-held roots. The broker receives only the derived Ed25519
# public map in .env.broker. JSON map values are independent base64 32-byte roots.
#BROKER_RECEIPT_ROOTS={"receipt-key-v1":"REPLACE_WITH_BASE64_32_BYTE_ROOT"}
BROKER_RECEIPT_CURRENT_VERSION=receipt-key-v1
BROKER_RECEIPT_DOMAIN=broker-receipt

BROKER_EXECUTION_LEASE_SECONDS=900
BROKER_GENERATION_DEADLINE_SECONDS=1800
BROKER_RECONCILE_INTERVAL_SECONDS=300

# -----------------------------------------------------------------------------
# Storage — Postgres (with pgvector)
# -----------------------------------------------------------------------------
POSTGRES_USER=openloop
POSTGRES_PASSWORD=change-me
POSTGRES_DB=openloop
DATABASE_URL=postgresql://openloop:change-me@localhost:5432/openloop
# Ordinary-query pool capacity per runtime replica. Budget replica count times
# POSTGRES_POOL_MAX_SIZE plus coordination/admin headroom below max_connections.
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=10

# -----------------------------------------------------------------------------
# Coordination — Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# Cross-process lock for multi-replica deploys, choosing who leads startup recovery:
#   auto     (default) follow effective storage mode — Postgres advisory lock
#            for auto/postgres storage, else process-local.
#   memory   force a process-local lock (single replica).
#   postgres force Postgres advisory locks (reuses DATABASE_URL; the connection is
#            the lease, so a crashed replica's lock frees immediately — no TTL).
#   redis    force a Redis lock (needs REDIS_URL + the `redis` extra: pip install '.[redis]').
# An explicit postgres/redis that can't start logs loudly then degrades to
# in-process; auto degrades quietly.
LOCK_BACKEND=auto
# How often (seconds) to re-run crash recovery under the lock — the backstop that
# heals a recovery leader that died mid-sweep. 0 = startup-only.
RECOVERY_INTERVAL_SECONDS=300

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# Logging level: debug | info | warning | error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Memory
# -----------------------------------------------------------------------------
# Backend: "memory" (process-local, no DB) or "postgres" (pgvector-backed).
# Storage policy: memory (process-local), auto (try Postgres and degrade per
# store), or postgres (durable and fail-fast). STORAGE_MODE takes precedence;
# MEMORY_BACKEND remains as a deprecated compatibility input when it is unset.
STORAGE_MODE=memory
# MEMORY_BACKEND=memory
# Semantic recall needs an embedding provider; set to false for recency-only.
EMBEDDINGS_ENABLED=true
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536
